<div class="container" style="margin-bottom: 3rem; border-top: 5px solid #764ba2;">
    <h2 style="color: #764ba2; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
        <span>📝</span> Añadir Nueva Tarea
    </h2>

    <form action="/nueva-tarjeta" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
        <div style="display: flex; flex-direction: column; gap: 5px;">
            <label style="font-weight: 600; color: #4a5568;">Título de la actividad</label>
            <input type="text" name="titulo" placeholder="Ej: Estudiar para el examen de Node" required 
                   style="padding: 12px; border: 2px solid #edf2f7; border-radius: 8px; font-size: 1rem;">
        </div>

        <div style="display: flex; flex-direction: column; gap: 5px;">
            <label style="font-weight: 600; color: #4a5568;">Descripción detallada</label>
            <textarea name="descripcion" placeholder="¿Qué necesitas hacer exactamente?" required rows="3"
                      style="padding: 12px; border: 2px solid #edf2f7; border-radius: 8px; font-size: 1rem; resize: none;"></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="align-self: flex-start; padding: 12px 30px; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
            <span>➕</span> Crear Tarjeta
        </button>
    </form>
</div>

<hr style="border: 0; height: 1px; background: #e2e8f0; margin-bottom: 2rem;">

<h3 style="color: #2d3748; margin-bottom: 1.5rem;">📌 Mis Tareas Pendientes</h3>
<section style="display: flex; flex-wrap: wrap; gap: 20px;">
    {{#each tareas}}
        <div class="card pending" style="position: relative;">
            <h4 style="color: #2c3e50;">{{this.titulo}}</h4>
            <p style="font-size: 0.9rem; color: #7f8c8d;">{{this.descripcion}}</p>
            
            <div style="display: flex; gap: 10px; margin-top: 15px;">
                <form action="/eliminar-tarjeta/{{this.id}}" method="POST" style="display:inline;">
                    <button type="submit" class="btn" style="background: #e74c3c; color: white; padding: 5px 10px; font-size: 0.8rem; border-radius: 4px;">
                        Borrar
                    </button>
                </form>

                <button onclick="editar('{{this.id}}', '{{this.titulo}}')" class="btn" style="background: #3498db; color: white; padding: 5px 10px; font-size: 0.8rem; border-radius: 4px;">
                    Editar 
                </button>
            </div>
        </div>
    {{/each}}
</section>

<script>
    function editar(id, tituloActual) {
        const nuevo = prompt("Editar título de la tarea:", tituloActual);
        if (nuevo) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/editar-tarjeta/${id}`;
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'nuevoTitulo';
            input.value = nuevo;
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>