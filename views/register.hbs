<section class="container" style="max-width: 400px; margin: 2rem auto;">
    <h2 style="text-align: center; margin-bottom: 1.5rem; color: #764ba2;">Crear Cuenta</h2>
    <form action="/register" method="POST"> <input type="text" name="nombre" placeholder="Tu Nombre Completo" required>
        <input type="email" name="email" placeholder="Tu Email" required>
        <input type="password" name="password" placeholder="Crea una Contraseña" required>
        <button type="submit" class="btn btn-primary">Registrarse</button>
    </form>
    <p style="text-align: center; margin-top: 1rem;">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
</section>